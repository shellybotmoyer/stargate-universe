    "@ggez/anim-schema": "^0.1.8",
    "@ggez/anim-three": "^0.1.8",
    "@ggez/game-dev": "^0.1.8",
    "@ggez/gameplay-runtime": "^0.1.8",
    "@ggez/render-pipeline": "^0.1.8",
    "@ggez/runtime-format": "^0.1.8",
    "@ggez/runtime-physics-crashcat": "^0.1.8",
    "@ggez/shared": "^0.1.8",
    "@ggez/three-runtime": "^0.1.8",
    "@pixiv/three-vrm": "^3.5.1",
    "@pixiv/three-vrm-animation": "^3.5.1",
    "mitt": "^3.0.1",
    "three": "^0.181.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260405.1",
    "@types/three": "^0.181.0",
    "esbuild": "^0.28.0",
