{
	"name": "stargate-universe",
	"private": true,
	"version": "0.0.0",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"start": "run-p dev dev:api",
		"dev": "bun run gen:pwa && vite",
		"dev:api": "wrangler pages dev dist --r2 GAME_ASSETS=sgu-assets --r2 GAME_DATA=sgu-game-data",
		"build": "bun run gen:pwa && tsc --noEmit && vite build",
		"gen:pwa": "bun run scripts/gen-manifest.ts && bun run scripts/gen-sw.ts",
		"preview": "vite preview --port 5173 --strictPort",
		"deploy": "bun run build && wrangler pages deploy dist",
		"typecheck": "tsc --noEmit",
		"test:e2e": "playwright test",
		"test:e2e:headed": "playwright test --headed",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:visual": "playwright test tests/visual/",
		"test:visual:update": "playwright test tests/visual/ --update-snapshots"
	},
	"dependencies": {
		"@ggez/anim-core": "^0.1.11",
		"@ggez/anim-exporter": "^0.1.11",
		"@ggez/anim-runtime": "^0.1.11",
		"@ggez/anim-schema": "^0.1.11",
		"@ggez/anim-three": "^0.1.11",
		"@ggez/game-dev": "^0.1.11",
		"@ggez/gameplay-runtime": "^0.1.11",
		"@ggez/render-pipeline": "^0.1.11",
		"@ggez/runtime-format": "^0.1.11",
		"@ggez/runtime-physics-crashcat": "^0.1.11",
		"@ggez/shared": "^0.1.11",
		"@ggez/three-runtime": "^0.1.11",
		"@pixiv/three-vrm": "^3.5.1",
		"@pixiv/three-vrm-animation": "^3.5.1",
		"mitt": "^3.0.1",
		"three": "^0.182.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260405.1",
		"@playwright/test": "^1.59.1",
		"@types/node": "^25.6.0",
		"@types/three": "^0.182.0",
		"esbuild": "^0.28.0",
		"npm-run-all2": "^8.0.4",
		"playwright": "^1.59.1",
		"typescript": "^5.9.3",
		"vite": "^7.1.12",
		"vitest": "^4.1.2",
		"wrangler": "^4.80.0"
	},
	"overrides": {
		"@types/three": "^0.182.0",
		"three": "^0.182.0"
	}
}
