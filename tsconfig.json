{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
	"moduleResolution": "Bundler",
	"paths": {
		"@kopertop/vibe-game-engine": ["./src/types/vibe-game-engine/index.d.ts"],
		"@kopertop/vibe-game-engine/*": ["./src/types/vibe-game-engine/*"]
	},
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
		"types": ["vite/client", "node"],
  },
  "include": ["src", "tests", "vitest.config.ts", "src/types/vibe-game-engine"]
}
